{
  "version": 2,
  "builds": [
    { "src": "package.json", "use": "@vercel/static-build" },
    { "src": "api/app.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/Brainstack/(.)", "dest": "/api/app.js" },
    { "src": "/assets/(.)", "dest": "/assets/$1" },
    { "src": "/(.\.(js|css|png|jpg|svg|ico|ttf|woff2?))", "dest": "/$1" },
    { "src": "/(.)", "dest": "/index.html" }
  ]
}